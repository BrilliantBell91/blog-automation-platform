# Database (Task 014: Turso 마이그레이션 완료)
# 로컬 파일: DATABASE_URL="file:./prisma/dev.db" (TURSO_AUTH_TOKEN 불필요)
# Turso(프로덕션 권장): DATABASE_URL="libsql://<db-name>-<org>.turso.io"
DATABASE_URL="file:./prisma/dev.db"
TURSO_AUTH_TOKEN=""

AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# Notion API (Task 006 구현 시 설정)
NOTION_API_KEY=""
NOTION_DATABASE_ID=""

# 관리자 계정 (Task 008에서 사용)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# LLM API (Task 009 구현, 과금 없는 무료 티어를 위해 Gemini로 전환됨)
# 참고: LLM_PROVIDER는 현재 미사용 (Gemini 하드코딩됨).
# PRD §12 "LLM 제공자" 미결 이슈에 따라 향후 다른 제공자 지원 대비 예약된 값
# LLM_API_KEY는 https://aistudio.google.com/apikey 에서 무료 발급
LLM_PROVIDER="gemini"
LLM_API_KEY=""

# Groq API (Gemini 무료 티어 할당량 소진 시 최종 폴백 — 선택사항, 없으면 폴백 없이 기존 동작)
# https://console.groq.com/keys 에서 무료 발급 (카드 등록 불필요)
GROQ_API_KEY=""

# On-Demand Revalidation (Task 012 구현 시 설정 — 선택사항)
# Notion webhook 등에서 /api/revalidate를 호출할 때 사용하는 secret 토큰
# 세션 없는 외부 호출 시에만 필요 (관리자 UI에서는 NextAuth 세션 사용)
REVALIDATE_SECRET=""

# 네이버 이미지 검색 API (초안 생성 시 실사 이미지 소싱 — 선택사항, 없으면 조용히 건너뜀)
# https://developers.naver.com 에서 애플리케이션 등록 후 발급
NAVER_SEARCH_CLIENT_ID=""
NAVER_SEARCH_CLIENT_SECRET=""

# 구글 이미지 검색 API (네이버 검색 보조 수단 — 선택사항, 없으면 조용히 건너뜀)
# GOOGLE_SEARCH_API_KEY: https://console.cloud.google.com/apis/credentials 에서 발급 (Custom Search API 활성화 필요)
# GOOGLE_SEARCH_CX: https://programmablesearchengine.google.com 에서 검색엔진 생성 후 cx 값 복사
# 2026-01-20부터 신규 검색엔진은 "전체 웹 검색"이 막히고 "검색할 사이트"에 등록한 최대 50개
# 도메인 내에서만 검색 가능 — 콘솔에서 도메인을 등록해야 실제로 결과가 나온다.
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_CX=""
